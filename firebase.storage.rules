rules_version = '2';

// Craft rules based on the provided request
// Allow read/write access to authenticated users only
service firebase.storage {
  match /b/{bucket}/o {
    // Only allow authenticated users to read or write any object
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Example: Stricter profile picture rules (uncomment if using profile pictures)
    // match /users/{userId}/profile.jpg {
    //   // Anyone authenticated can read
    //   allow read: if request.auth != null;
    //   // Only the user themselves can upload, and it must be an image under 5MB
    //   allow write: if request.auth != null 
    //                && request.auth.uid == userId
    //                && request.resource.contentType.matches('image/.*')
    //                && request.resource.size < 5 * 1024 * 1024;
    // }
  }
}
